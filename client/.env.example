# Client Environment Variables
# Please provide the actual values below

# MongoDB Connection String (Required for BetterAuth)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/crowdfunding?retryWrites=true&w=majority

# BetterAuth Secret (Required - You can generate one using `openssl rand -base64 32`)
BETTER_AUTH_SECRET=your_super_secret_string

# BetterAuth Base URL (Required - URL of the Next.js app)
BETTER_AUTH_URL=http://localhost:3000

# Next.js Public API URL (Required - URL of the Express backend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Google OAuth Credentials (Required if using Google Sign-in)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
